<Window x:Class="Trebuchet.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Trebuchet"
        mc:Ignorable="d"
        Title="About Trebuchet Auto-Runner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        MinWidth="320">
    <StackPanel>
        <TextBlock Text="Trebuchet Auto-Runner" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"></TextBlock>
        <Image Source="/icon.png" Width="64" Height="64" HorizontalAlignment="Center"></Image>
        <TextBlock Text="{Binding Version, Mode=OneTime}" FontSize="14" TextAlignment="Center"
                   HorizontalAlignment="Center" Margin="10"></TextBlock>
        <TextBlock Text="{Binding Copyright, Mode=OneTime}" FontSize="14" TextAlignment="Center" HorizontalAlignment="Center" Margin="10"></TextBlock>
        <TextBlock HorizontalAlignment="Center" Margin="10">
            <Hyperlink NavigateUri="{Binding RepositoryUrl, Mode=OneTime}" RequestNavigate="Hyperlink_OnRequestNavigate">
                View on GitHub
            </Hyperlink>
        </TextBlock>
        <Button x:Name="CloseButton" Content="Close" Margin="10" Click="CloseButton_OnClick"></Button>
    </StackPanel>
</Window>
