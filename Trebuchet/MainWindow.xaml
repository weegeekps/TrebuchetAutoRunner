<Window x:Class="Trebuchet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Trebuchet"
        mc:Ignorable="d"
        Title="Trebuchet Auto-Runner" MinWidth="240"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Icon="/icon.png">
    <StackPanel x:Name="ButtonList">
        <StackPanel.Resources>
            <Style TargetType="Button">
                <Setter Property="FontSize" Value="16"></Setter>
                <Setter Property="Margin" Value="20, 0,20,10" />
            </Style>
        </StackPanel.Resources>
        <TextBlock Text="Trebuchet Auto-Runner" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"></TextBlock>
        <Image Source="/icon.png" Width="64" Height="64"></Image>
        <TextBlock Text="Choose an Installer to Launch" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="10,0,10, 5" />
        <TextBlock Text="{Binding Instructions}" Width="220"  FontSize="14" TextAlignment="Center" HorizontalAlignment="Center" FontStyle="Italic" TextWrapping="Wrap" Margin="0, 0, 0, 10" />
        <!-- Buttons will be added here dynamically -->
        <Button x:Name="ExitButton" Content="Exit" Click="ExitButton_OnClick" />
        <Button x:Name="OpenAbout" Content="About..." Click="OpenAbout_OnClick"></Button>
    </StackPanel>
</Window>
